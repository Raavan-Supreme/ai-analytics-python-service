# Local LLM settings for python-service
# Use one of: none, ollama, lmstudio, openai_compatible
LOCAL_LLM_PROVIDER=ollama

# For Ollama: http://localhost:11434
# For LM Studio/OpenAI-compatible local server: http://localhost:1234
LOCAL_LLM_BASE_URL=http://localhost:11434

# Default local model
LOCAL_LLM_MODEL=phi3:mini
LOCAL_LLM_FALLBACK_MODELS=phi3:mini,mistral:7b-instruct,llama3.2:3b

# Base generation config (used for pandas-code generation)
LOCAL_LLM_TEMPERATURE=0.1
LOCAL_LLM_MAX_TOKENS=2000
LOCAL_LLM_TIMEOUT_SEC=60

# Query understanding layer (semantic rewrite + alternatives)
APP_LLM_QUERY_UNDERSTANDING=true
LOCAL_LLM_UNDERSTAND_MODEL=phi3:mini
LOCAL_LLM_UNDERSTAND_TEMPERATURE=0.2
LOCAL_LLM_UNDERSTAND_MAX_TOKENS=1400
LOCAL_LLM_UNDERSTAND_TIMEOUT_SEC=75

# Optional trace toggles
APP_QUERY_TRACE=true
APP_LLM_TRACE=true
APP_QUERY_TRACE_INCLUDE_RESPONSE=false
